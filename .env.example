# AI API 密钥配置示例
# 复制此文件为 .env 并填入您的实际API密钥

# DeepSeek API密钥
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq API密钥  
GROQ_API_KEY=your_groq_api_key_here

# Mistral API密钥
MISTRAL_API_KEY=your_mistral_api_key_here

# Cohere API密钥
COHERE_API_KEY=your_cohere_api_key_here

# OpenAI API密钥
OPENAI_API_KEY=your_openai_api_key_here

# 代理（ai-lib-rust）：Groq 等需翻墙时用；DeepSeek 在境内可直连时请配绕过列表
# AI_PROXY_URL=http://127.0.0.1:7890
# 方式 A：标准环境变量（与 curl 等一致）
# NO_PROXY=api.deepseek.com,.deepseek.com,localhost,127.0.0.1
# 方式 B：仅作用于本应用（不污染全局 NO_PROXY）
# AI_PROXY_NO_PROXY=api.deepseek.com,.deepseek.com,localhost,127.0.0.1

# 日志级别
RUST_LOG=info